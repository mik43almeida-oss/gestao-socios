# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Configurações do MongoDB
MONGO_URI=mongodb://localhost:27017/gestao_socios
MONGO_TEST_URI=mongodb://localhost:27017/gestao_socios_test

# Configurações JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_minimo_32_caracteres_aleatorios
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=sua_chave_refresh_secreta_minimo_32_caracteres_aleatorios
JWT_REFRESH_EXPIRE=7d

# Configurações de Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
EMAIL_FROM=noreply@suasociedade.com
EMAIL_ADMIN=admin@suasociedade.com

# Configurações de API Externa (Multibanco/MB WAY)
MULTIBANCO_API_KEY=sua_chave_api_multibanco
MBWAY_API_KEY=sua_chave_api_mbway
MBWAY_MERCHANT_ID=seu_merchant_id

# Configurações de Segurança
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15

# Configurações de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configurações CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Configurações de Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Configurações de Log
LOG_LEVEL=info
LOG_FILE=logs/app.log
